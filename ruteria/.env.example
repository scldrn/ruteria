# Supabase project URL (from supabase status → API URL)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe for client-side use
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server/Edge Functions only, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=

# Base URL used for auth redirects (e.g. http://localhost:3000 in local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional comma-separated origins for mobile testing with `next dev`
# Example: NEXT_ALLOWED_DEV_ORIGINS=192.168.1.10,10.0.0.15
NEXT_ALLOWED_DEV_ORIGINS=

# Direct PostgreSQL password (used by migrations and CI)
SUPABASE_DB_PASSWORD=

# Supabase Storage bucket name for visit photos
STORAGE_BUCKET_FOTOS=fotos-visita

# Shared secret required by privileged internal jobs (Edge cron, schedulers)
INTERNAL_CRON_SECRET=
